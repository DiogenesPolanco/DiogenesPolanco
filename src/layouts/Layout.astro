---
interface Props {
  title?: string;
}

const { title = "Diogenes Polanco" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Manager of Development, Projects and Innovation - .NET, TypeScript, Angular, Microservices, AI/LLMs" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <div class="page-background"></div>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>